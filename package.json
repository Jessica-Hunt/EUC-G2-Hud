{
  "name": "euc-world-g2",
  "version": "1.0.0",
  "description": "EUC World live ride HUD for Even G2 smart glasses",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":       "vite",
    "build":     "tsc && vite build",
    "preview":   "vite preview",
    "simulate":  "evenhub-simulator http://localhost:5173",
    "qr":        "evenhub qr --url",
    "pack":      "evenhub pack app.json dist -o euc-world-g2.ehpk"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "latest"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli":       "latest",
    "@evenrealities/evenhub-simulator": "latest",
    "typescript":                       "^5.4.0",
    "vite":                             "^5.2.0"
  }
}
